<mxfile host="app.diagrams.net">
  <diagram name="Page-1" id="msg-pipeline-001">
    <mxGraphModel dx="1261" dy="1011" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" parent="1" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];fontSize=14;fontStyle=1;" value="Message Sync &amp; Processing Pipeline" vertex="1">
          <mxGeometry x="60" y="20" width="350" height="30" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" parent="1" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];fontSize=10;fontColor=#666;" value="Visitor pattern — same pipeline handles partial (headers) and full (body) messages" vertex="1">
          <mxGeometry x="60" y="45" width="500" height="20" as="geometry" />
        </mxCell>

        <!-- ① Message Received -->
        <mxCell id="e_recv_pipeline" edge="1" parent="1" source="msg_received" target="pipeline" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" value="" />
        <mxCell id="msg_received" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" value="Message&lt;br&gt;Received" vertex="1">
          <mxGeometry x="340" y="80" width="120" height="60" as="geometry" />
        </mxCell>
        <mxCell id="recv_detail" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontSize=9;fontColor=#666;" value="&lt;div&gt;sync/imap.rs&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;Phase 1:&lt;/b&gt; FETCH (ENVELOPE FLAGS UID BODYSTRUCTURE)&lt;/div&gt;&lt;div&gt;&lt;b&gt;Phase 2:&lt;/b&gt; FETCH (BODY[] for text parts)&lt;/div&gt;&lt;div&gt;&lt;b&gt;IDLE:&lt;/b&gt; new message notification&lt;/div&gt;" vertex="1">
          <mxGeometry x="480" y="70" width="280" height="80" as="geometry" />
        </mxCell>

        <!-- Raw email label on arrow -->
        <mxCell id="raw_label" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontSize=9;" value="RawEmail (partial or full)" vertex="1">
          <mxGeometry x="410" y="170" width="160" height="25" as="geometry" />
        </mxCell>

        <!-- ② Email Processing Pipeline -->
        <mxCell id="e_pipeline_engine" edge="1" parent="1" source="pipeline" target="engine" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" value="" />
        <mxCell id="pipeline" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" value="Email Processing&lt;br&gt;Pipeline" vertex="1">
          <mxGeometry x="340" y="240" width="120" height="60" as="geometry" />
        </mxCell>

        <!-- Visitor steps (expanded) -->
        <mxCell id="pipeline_detail" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;rounded=0;fontSize=9;fontColor=#666;" value="&lt;div&gt;engine/pipeline.rs&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;trait ProcessingStep&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; fn process(&amp;amp;self, msg: &amp;amp;mut MailMessage, raw: &amp;amp;RawEmail)&lt;/div&gt;" vertex="1">
          <mxGeometry x="480" y="225" width="300" height="60" as="geometry" />
        </mxCell>

        <!-- Visitor steps list -->
        <mxCell id="steps_box" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=1;dashed=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fontSize=9;" value="&lt;b&gt;Steps (run in order):&lt;/b&gt;&lt;br&gt;&lt;br&gt;✓ ExtractMetadata — from, to, date, subject, message-id&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;(always succeeds — headers always present)&lt;br&gt;&lt;br&gt;✓ ExtractFlags — seen, flagged, answered, draft&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;(always succeeds — flags always present)&lt;br&gt;&lt;br&gt;○ ExtractPreview — first ~200 chars of text body&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;(no-op if body not fetched yet)&lt;br&gt;&lt;br&gt;○ ExtractAttachments — name, mime type, size from parts&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;(no-op if BODYSTRUCTURE not available)&lt;br&gt;&lt;br&gt;○ DetectContentType — plain / HTML / multipart&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;(no-op if body not fetched yet)" vertex="1">
          <mxGeometry x="480" y="300" width="300" height="195" as="geometry" />
        </mxCell>

        <!-- Legend for step symbols -->
        <mxCell id="step_legend" parent="1" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];fontSize=8;fontColor=#82b366;" value="✓ = always runs &amp;nbsp; ○ = skips gracefully if data missing" vertex="1">
          <mxGeometry x="480" y="498" width="280" height="15" as="geometry" />
        </mxCell>

        <!-- Processed label on arrow -->
        <mxCell id="processed_label" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontSize=9;" value="MailMessage (partially or fully populated)" vertex="1">
          <mxGeometry x="410" y="330" width="60" height="50" as="geometry" />
        </mxCell>

        <!-- ③ Engine -->
        <mxCell id="engine" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="Engine" vertex="1">
          <mxGeometry x="340" y="420" width="120" height="60" as="geometry" />
        </mxCell>
        <mxCell id="engine_detail" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontSize=9;fontColor=#666;" value="&lt;div&gt;engine/messages.rs&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Persist to SQLite (content hash)&lt;/div&gt;&lt;div&gt;Merge partial → fills gaps, doesn't overwrite&lt;/div&gt;&lt;div&gt;Emit MessagesChanged event&lt;/div&gt;&lt;div&gt;Serve cached data to UI&lt;/div&gt;" vertex="1">
          <mxGeometry x="100" y="520" width="250" height="80" as="geometry" />
        </mxCell>

        <!-- Re-run arrow (Phase 2 feeds back through same pipeline) -->
        <mxCell id="rerun_label" parent="1" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=8;fontColor=#82b366;fontStyle=2;" value="Phase 2: re-run with body data&lt;br&gt;fills in preview, attachments, content type" vertex="1">
          <mxGeometry x="100" y="300" width="200" height="30" as="geometry" />
        </mxCell>
        <mxCell id="e_rerun" edge="1" parent="1" source="engine" target="pipeline" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#82b366;dashed=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" value="">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="300" y="450" />
              <mxPoint x="300" y="270" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Flow numbers -->
        <mxCell id="n1" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#333;fontColor=#fff;fontSize=10;fontStyle=1;" value="1" vertex="1">
          <mxGeometry x="310" y="98" width="22" height="22" as="geometry" />
        </mxCell>
        <mxCell id="n2" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#333;fontColor=#fff;fontSize=10;fontStyle=1;" value="2" vertex="1">
          <mxGeometry x="310" y="258" width="22" height="22" as="geometry" />
        </mxCell>
        <mxCell id="n3" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#333;fontColor=#fff;fontSize=10;fontStyle=1;" value="3" vertex="1">
          <mxGeometry x="310" y="438" width="22" height="22" as="geometry" />
        </mxCell>

        <!-- Legend -->
        <mxCell id="legend" parent="1" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];fontSize=9;fontColor=#333;" value="&lt;b&gt;Flow:&lt;/b&gt;&lt;br&gt;① IMAP FETCH retrieves raw message (headers-only or full)&lt;br&gt;② Pipeline runs all steps — each step skips gracefully if its data is missing&lt;br&gt;③ Engine persists MailMessage (merges partial updates), emits event&lt;br&gt;&lt;br&gt;&lt;b&gt;Phase 2 re-run:&lt;/b&gt; when body is fetched later, same message goes through&lt;br&gt;the same pipeline again — body-dependent steps now fill in their fields" vertex="1">
          <mxGeometry x="60" y="620" width="420" height="90" as="geometry" />
        </mxCell>

        <!-- Layer labels (left side) -->
        <mxCell id="layer_sync" parent="1" style="text;html=1;align=right;verticalAlign=middle;resizable=0;points=[];fontSize=9;fontStyle=2;fontColor=#d6b656;" value="sync/" vertex="1">
          <mxGeometry x="260" y="80" width="40" height="60" as="geometry" />
        </mxCell>
        <mxCell id="layer_engine" parent="1" style="text;html=1;align=right;verticalAlign=middle;resizable=0;points=[];fontSize=9;fontStyle=2;fontColor=#82b366;" value="engine/" vertex="1">
          <mxGeometry x="250" y="240" width="50" height="60" as="geometry" />
        </mxCell>
        <mxCell id="layer_engine2" parent="1" style="text;html=1;align=right;verticalAlign=middle;resizable=0;points=[];fontSize=9;fontStyle=2;fontColor=#6c8ebf;" value="engine/" vertex="1">
          <mxGeometry x="250" y="420" width="50" height="60" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
